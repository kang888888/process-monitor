{
  "name": "process-monitor",
  "version": "1.0.0",
  "description": "进程监控 - Electron 桌面壳",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "prebuild:win": "node scripts/prepare-app.js",
    "build:win": "npm run prebuild:win && electron-builder --win"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.process-monitor.app",
    "productName": "进程监控",
    "directories": {
      "output": "dist-win"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      { "from": ".electron-app", "to": "app" }
    ],
    "forceCodeSigning": false,
    "win": {
      "target": ["nsis"],
      "icon": null,
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
